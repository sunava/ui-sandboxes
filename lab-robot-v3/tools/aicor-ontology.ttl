            owl:onProperty :representsSelfStateOf ;
            owl:someValuesFrom :ManipulationExecutive ],
        :AbstractEntity,
        :dul_InformationObject,
        owl:Thing ;
    owl:disjointWith :SemanticDigitalTwin .

:RegimeDependentProperty a owl:Class ;
    rdfs:label "RegimeDependentProperty"^^xsd:string ;
    rdfs:subClassOf :AbstractEntity,
