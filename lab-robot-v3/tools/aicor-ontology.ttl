:ReflectiveRepresentation a owl:Class ;
    rdfs:label "ReflectiveRepresentation"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :enables ;
            owl:someValuesFrom :ResponsibleNonAccomplishment ],
