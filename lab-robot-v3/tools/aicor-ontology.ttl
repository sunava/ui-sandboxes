        [ a owl:Restriction ;
            owl:onProperty :interprets ;
            owl:someValuesFrom :Recording ],
        [ a owl:Restriction ;
            owl:hasValue true ;
            owl:onProperty :isCriticRelative ],
        :dul_InformationObject,
        owl:Thing ;
    owl:disjointWith :ManipulationEpisode,
        :Recording .

:ManipulationProblemClass a owl:Class ;
    rdfs:label "ManipulationProblemClass"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue false ;
            owl:onProperty :isRWMSComponent ],
        [ a owl:Restriction ;
            owl:onClass :MasteryCriterion ;
            owl:onProperty :hasMasteryCriterion ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onProperty :generates ;
            owl:someValuesFrom :ProblemDomain ],
        [ a owl:Restriction ;
            owl:hasValue true ;
            owl:onProperty :isGenerator ],
        [ a owl:Restriction ;
            owl:onClass :RWMSFamily ;
            owl:onProperty :hasRWMSFamily ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass :NuisanceModel ;
            owl:onProperty :hasNuisanceModel ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onProperty :hasCriticSet ;
            owl:someValuesFrom :Critic ],
        [ a owl:Restriction ;
            owl:onProperty :specifiedBy ;
            owl:someValuesFrom :ProblemClassSpecificationTemplate ],
        [ a owl:Restriction ;
            owl:onClass :TaskScope ;
            owl:onProperty :hasTaskScope ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        :AbstractEntity,
        :dul_Description,
        owl:Thing ;
    owl:disjointWith :ProblemDomain .

:TimeInterval a owl:Class ;
    rdfs:label "TimeInterval"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :hasStart ;
            owl:someValuesFrom :TimeInstant ],
        [ a owl:Restriction ;
            owl:onProperty :hasEnd ;
            owl:someValuesFrom :TimeInstant ],
        :AbstractEntity,
        :dul_Region,
        owl:Thing ;
    owl:disjointWith :Chronicle,
        :EventType,
        :FluentType,
        :Occurrence .

:hasProperPart a owl:ObjectProperty .

:partOf a owl:ObjectProperty .

:EventType a owl:Class ;
    rdfs:label "EventType"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :occursOver ;
            owl:someValuesFrom :TimeInterval ],
        [ a owl:Restriction ;
            owl:hasValue false ;
            owl:onProperty :homogeneous ],
        :AbstractEntity,
        :dul_Description,
        owl:Thing ;
    owl:disjointWith :Chronicle,
        :FluentType,
        :TimeInterval .

:RobotBody a owl:Class ;
    rdfs:label "RobotBody"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :hasSensor ;
            owl:someValuesFrom :Sensor ],
        [ a owl:Restriction ;
            owl:onProperty :hasLink ;
            owl:someValuesFrom :Link ],
        [ a owl:Restriction ;
            owl:onProperty :hasEndEffector ;
            owl:someValuesFrom :EndEffector ],
        [ a owl:Restriction ;
            owl:onProperty :generates ;
            owl:someValuesFrom :BodyMotion ],
        [ a owl:Restriction ;
            owl:onProperty :hasJoint ;
            owl:someValuesFrom :Joint ],
        :ArticulatedObject,
        :PhysicalEntity,
        owl:Thing ;
    owl:disjointWith :ManipulationExecutive,
        :WorldPhysicalEntity .

:dul_Region a owl:Class ;
    rdfs:label "dul:Region"^^xsd:string ;
    rdfs:subClassOf :AbstractEntity,
        owl:Thing .

:ManipulationEpisode a owl:Class ;
    rdfs:label "ManipulationEpisode"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass :CommitmentRecord ;
            owl:onProperty :hasCommitmentRecord ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onProperty :isRunOf ;
            owl:someValuesFrom :RobotWorldManipulationSystem ],
        [ a owl:Restriction ;
            owl:onClass :ExecutiveEstimate ;
            owl:onProperty :hasExecutiveEstimate ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onProperty :hasTrace ;
            owl:someValuesFrom :EvidenceBearingTrace ],
        [ a owl:Restriction ;
            owl:onProperty :hasLifecycleEvents ;
            owl:someValuesFrom :LifecycleEvent ],
        [ a owl:Restriction ;
            owl:onClass :TaskRequest ;
            owl:onProperty :hasRequest ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:hasValue true ;
            owl:onProperty :isHierarchical ],
        [ a owl:Restriction ;
            owl:onProperty :hasVerdictComponent ;
            owl:someValuesFrom :VerdictComponent ],
        [ a owl:Restriction ;
            owl:onClass :BodyWorldTrajectory ;
            owl:onProperty :hasPhysicalCore ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :TaskEnvironmentEmbodimentClass ;
            owl:onProperty :conformsToScope ],
        [ a owl:Restriction ;
            owl:onClass :Recording ;
            owl:onProperty :hasRecording ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:hasValue true ;
            owl:onProperty :isBounded ],
        [ a owl:Restriction ;
            owl:onClass :TerminalDisposition ;
            owl:onProperty :hasTerminalDisposition ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        :AbstractEntity,
        :dul_Situation,
        owl:Thing ;
    owl:disjointWith :ForceDynamicSchema,
        :RobotWorldManipulationSystem .

:dul_PhysicalObject a owl:Class ;
    rdfs:label "dul:PhysicalObject"^^xsd:string ;
    rdfs:subClassOf :PhysicalEntity,
        owl:Thing .

:PhysicalEntity a owl:Class ;
    rdfs:subClassOf owl:Thing ;
    owl:disjointWith :AbstractEntity .

:ManipulationExecutive a owl:Class ;
    rdfs:label "ManipulationExecutive"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :generates ;
            owl:someValuesFrom :ActionToken ],
        [ a owl:Restriction ;
            owl:hasValue true ;
            owl:onProperty :isAccountable ],
        [ a owl:Restriction ;
            owl:onProperty :discharges ;
            owl:someValuesFrom :RepresentationalObligation ],
        [ a owl:Restriction ;
            owl:onProperty :controls ;
            owl:someValuesFrom :BodyWorldSystem ],
        :AbstractEntity,
        :dul_Agent,
        owl:Thing ;
    owl:disjointWith :BodyWorldSystem,
        :ProposalMechanism,
        :Robot .

:BodyWorldSystem a owl:Class ;
    rdfs:label "BodyWorldSystem"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :hasProperPart ;
            owl:someValuesFrom :WorldPhysicalEntity ],
        [ a owl:Restriction ;
            owl:onProperty :hasProperPart ;
            owl:someValuesFrom :RobotBody ],
        [ a owl:Restriction ;
            owl:hasValue true ;
            owl:onProperty :boundaryTaskRelative ],
        [ a owl:Restriction ;
            owl:onProperty :hasCoupling ;
            owl:someValuesFrom :ForceInteraction ],
        :PhysicalEntity,
        :dul_PhysicalObject,
        owl:Thing ;
    owl:disjointWith :ManipulationEpisode,
        :SceneGraph .

:dul_InformationObject a owl:Class ;
    rdfs:label "dul:InformationObject"^^xsd:string ;
    rdfs:subClassOf :AbstractEntity,
        owl:Thing .

:dul_Description a owl:Class ;
    rdfs:label "dul:Description"^^xsd:string ;
    rdfs:subClassOf :AbstractEntity,
        owl:Thing .

:AbstractEntity a owl:Class ;
    rdfs:subClassOf owl:Thing .

