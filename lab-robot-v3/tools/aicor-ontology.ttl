:Process a owl:Class ;
    rdfs:label "Process"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue "substanceDynamics"^^xsd:string ;
            owl:onProperty :governedBy ],
