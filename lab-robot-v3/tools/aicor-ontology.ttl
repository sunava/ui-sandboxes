:TriplePattern a owl:Class ;
    rdfs:label "TriplePattern"^^xsd:string ;
    rdfs:subClassOf :dul_InformationObject,
        owl:Thing .

:VLAModel a owl:Class ;
    rdfs:label "VLAModel"^^xsd:string ;
    rdfs:subClassOf owl:Thing .

:WorldOccurrence a owl:Class ;
    rdfs:label "WorldOccurrence"^^xsd:string ;
    rdfs:subClassOf :AbstractEntity,
        :Occurrence,
        owl:Thing ;
    owl:disjointWith :BeliefOccurrence .

:WorldState a owl:Class ;
    rdfs:label "WorldState"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass :ContinuousState ;
            owl:onProperty :hasContinuousState ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass :DiscreteModeStructure ;
            owl:onProperty :hasDiscreteMode ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        :PhysicalEntity,
        :dul_PhysicalObject,
