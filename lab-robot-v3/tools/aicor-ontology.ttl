:ProposalToCommitmentPipeline a owl:Class ;
    rdfs:label "ProposalToCommitmentPipeline"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :pipelineOf ;
            owl:someValuesFrom :DualProcessManipulationExecutive ],
        [ a owl:Restriction ;
            owl:onProperty :operationalizes ;
            owl:someValuesFrom :ProposalNotCommitment ],
        :AbstractEntity,
        :dul_Description,
        owl:Thing .

:QueryTemplate a owl:Class ;
    rdfs:label "QueryTemplate"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :templateOf ;
            owl:someValuesFrom :KnowledgeQueryLanguage ],
        [ a owl:Restriction ;
