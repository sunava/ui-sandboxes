@prefix : <http://aicor.knowledge/l2-ontology.owl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://aicor.knowledge/l2-ontology.owl> a owl:Ontology .

:AICORReferenceManipulationExecutive a owl:Class ;
    rdfs:label "AICORReferenceManipulationExecutive"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass :ManipulationControlProgram ;
            owl:onProperty :hasProperPart ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass :ManipulationExecutiveOperatingSystem ;
            owl:onProperty :hasProperPart ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:hasValue false ;
            owl:onProperty :isArchitectureNeutral ],
        :ManipulationExecutive,
        owl:Thing .

:AbstentionSignal a owl:Class ;
    rdfs:label "AbstentionSignal"^^xsd:string ;
    rdfs:subClassOf :Signal,
        owl:Thing .

:AccountableImplementationStructure a owl:Class ;
    rdfs:label "AccountableImplementationStructure"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :characterizes ;
            owl:someValuesFrom :ComputationalMedium ],
        :AbstractEntity,
        :dul_Description,
        owl:Thing .

:AchievementGoal a owl:Class ;
    rdfs:label "AchievementGoal"^^xsd:string ;
    rdfs:subClassOf :Goal,
        owl:Thing .

:ActionEventType a owl:Class ;
    rdfs:label "ActionEventType"^^xsd:string ;
    rdfs:subClassOf :AbstractEntity,
        :EventType,
        owl:Thing .

:ActionProposalResource a owl:Class ;
    rdfs:label "ActionProposalResource"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue true ;
            owl:onProperty :nearActionInterface ],
        :AbstractEntity,
        :dul_Description,
        owl:Thing .

:ActionReferent a owl:Class ;
    rdfs:label "ActionReferent"^^xsd:string ;
    rdfs:subClassOf :AbstractEntity,
        owl:Thing .

:ActionRelatedForceCorridor a owl:Class ;
    rdfs:label "ActionRelatedForceCorridor"^^xsd:string ;
    rdfs:subClassOf owl:Thing .

:ActionRelatedGrasp a owl:Class ;
    rdfs:label "ActionRelatedGrasp"^^xsd:string ;
    rdfs:subClassOf owl:Thing .

:ActionRelatedMotion a owl:Class ;
    rdfs:label "ActionRelatedMotion"^^xsd:string ;
    rdfs:subClassOf owl:Thing .

:ActionRelatedPlace a owl:Class ;
    rdfs:label "ActionRelatedPlace"^^xsd:string ;
    rdfs:subClassOf owl:Thing .

:ActionRelatedPour a owl:Class ;
    rdfs:label "ActionRelatedPour"^^xsd:string ;
    rdfs:subClassOf owl:Thing .

:AdmissibleAction a owl:Class ;
    rdfs:label "AdmissibleAction"^^xsd:string ;
    rdfs:subClassOf :CandidateAction,
        owl:Thing .

:CapabilityAssertion a owl:Class ;
    rdfs:label "CapabilityAssertion"^^xsd:string ;
    rdfs:subClassOf :AbstractEntity,
        :BodyWorldConstraint,
        owl:Thing .

:CausalAdmissibility a owl:Class ;
    rdfs:label "CausalAdmissibility"^^xsd:string ;
    rdfs:subClassOf :AbstractEntity,
        :dul_Description,
        owl:Thing .

:CompletionSignal a owl:Class ;
    rdfs:label "CompletionSignal"^^xsd:string ;
    rdfs:subClassOf :Signal,
        owl:Thing .

:ComponentCompetenceClaim a owl:Class ;
    rdfs:label "ComponentCompetenceClaim"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :requiresDeclaredScope ;
            owl:someValuesFrom :ResponsibleClaimScope ],
        :CompetenceClaim,
        owl:Thing .

:ConceptFamily a owl:Class ;
    rdfs:label "ConceptFamily"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass :AccountabilityQuestion ;
            owl:onProperty :answersQuestion ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        :AbstractEntity,
        :dul_Concept,
        owl:Thing .

:ConceptFamilyEnum a owl:Class ;
    rdfs:label "ConceptFamilyEnum"^^xsd:string ;
    rdfs:subClassOf owl:Thing .

:Constraint a owl:Class ;
    rdfs:label "Constraint"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue "motionManifold"^^xsd:string ;
            owl:onProperty :governedBy ],
        :CouplingType,
        owl:Thing .

:ConstraintBasedControl a owl:Class ;
    rdfs:label "ConstraintBasedControl"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :expressesTaskAs ;
            owl:someValuesFrom :ConstraintSet ],
        [ a owl:Restriction ;
            owl:onProperty :solvesFor ;
            owl:someValuesFrom :ActuatorInput ],
        :AbstractEntity,
        :RobotControlLaw,
        owl:Thing .

:CouplingTerm a owl:Class ;
    rdfs:label "CouplingTerm"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :hasCouplingType ;
            owl:someValuesFrom :CouplingType ],
        :dul_Description,
        owl:Thing .

:DataGenerationEngine a owl:Class ;
    rdfs:label "DataGenerationEngine"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :usesModel ;
            owl:someValuesFrom :DigitalBodyWorldSystem ],
        :dul_InformationObject,
        owl:Thing .

:Deictic a owl:Class ;
    rdfs:label "Deictic"^^xsd:string ;
    rdfs:subClassOf owl:Thing .

:DependencyEdge a owl:Class ;
    rdfs:label "DependencyEdge"^^xsd:string ;
    rdfs:subClassOf :dul_Description,
        owl:Thing .

:Descriptive a owl:Class ;
    rdfs:label "Descriptive"^^xsd:string ;
    rdfs:subClassOf owl:Thing .

:Designator a owl:Class ;
    rdfs:label "Designator"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :resolvesTo ;
            owl:someValuesFrom :DesignatorResolution ],
        [ a owl:Restriction ;
            owl:onProperty :resolvesVia ;
            owl:someValuesFrom :ResolutionMode ],
        [ a owl:Restriction ;
            owl:onProperty :references ;
            owl:someValuesFrom :DesignatorTarget ],
        [ a owl:Restriction ;
            owl:hasValue true ;
            owl:onProperty :lazy ],
        :dul_Description,
        owl:Thing .

:DesignatorReferent a owl:Class ;
    rdfs:label "DesignatorReferent"^^xsd:string ;
    rdfs:subClassOf owl:Thing .

:DigitalResearchLaboratory a owl:Class ;
    rdfs:label "DigitalResearchLaboratory"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :usesModel ;
            owl:someValuesFrom :DigitalBodyWorldSystem ],
        :dul_InformationObject,
        owl:Thing .

:DownstreamModel a owl:Class ;
    rdfs:label "DownstreamModel"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :integratedInto ;
            owl:someValuesFrom :CommitmentRelevantStructure ],
        :AbstractEntity,
        :dul_Description,
        owl:Thing .

:EnvisionedTimeline a owl:Class ;
    rdfs:label "EnvisionedTimeline"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue true ;
            owl:onProperty :isGroundedInSimulation ],
        [ a owl:Restriction ;
            owl:onProperty :projectionOfBranch ;
            owl:someValuesFrom :ManipulationEpisode ],
        [ a owl:Restriction ;
            owl:onProperty :relativeToScenario ;
            owl:someValuesFrom :Scenario ],
        [ a owl:Restriction ;
            owl:onProperty :producedByEnvisioning ;
            owl:someValuesFrom :Envisioning ],
        [ a owl:Restriction ;
            owl:onProperty :translatedFrom ;
            owl:someValuesFrom :SimulationLog ],
        :dul_InformationObject,
        owl:Thing ;
    owl:disjointWith :SimulationLog .

:ExecutiveBehaviouralSpecification a owl:Class ;
    rdfs:label "ExecutiveBehaviouralSpecification"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :hasProperty ;
            owl:someValuesFrom :ExecutiveProperty ],
        [ a owl:Restriction ;
            owl:onProperty :specifies ;
            owl:someValuesFrom :ManipulationExecutive ],
        [ a owl:Restriction ;
            owl:onProperty :relativeToProblemFamily ;
            owl:someValuesFrom :ManipulationProblemClass ],
        :AbstractEntity,
        :dul_Description,
        owl:Thing ;
    owl:disjointWith :ManipulationExecutive .

:ExecutiveRealization a owl:Class ;
    rdfs:label "ExecutiveRealization"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :distinctFrom ;
            owl:someValuesFrom :ExecutiveArchitecture ],
        [ a owl:Restriction ;
            owl:onProperty :realizationOf ;
            owl:someValuesFrom :ManipulationExecutive ],
        :AbstractEntity,
        :dul_Description,
        owl:Thing .

:FailureSignal a owl:Class ;
    rdfs:label "FailureSignal"^^xsd:string ;
    rdfs:subClassOf :Signal,
        owl:Thing .

:Force a owl:Class ;
    rdfs:label "Force"^^xsd:string ;
    rdfs:subClassOf :PhysicalEntity,
        owl:Thing .

:ForceClosure a owl:Class ;
    rdfs:label "ForceClosure"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue "frictionCone"^^xsd:string ;
            owl:onProperty :governedBy ],
        :CouplingType,
        owl:Thing .

:GroundedManipulationProblem a owl:Class ;
    rdfs:label "GroundedManipulationProblem"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :hasNuisanceCondition ;
            owl:someValuesFrom :NuisanceComponent ],
        [ a owl:Restriction ;
            owl:onProperty :generatesTrace ;
            owl:someValuesFrom :ManipulationEpisode ],
        [ a owl:Restriction ;
            owl:onClass :BodyWorldSystem ;
            owl:onProperty :hasBodyWorldSystem ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass :BWSRelativeTaskSpecification ;
            owl:onProperty :hasTaskSpecification ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:hasValue true ;
            owl:onProperty :isAssessmentInput ],
        [ a owl:Restriction ;
            owl:onProperty :memberOf ;
            owl:someValuesFrom :ProblemDomain ],
        [ a owl:Restriction ;
            owl:hasValue false ;
            owl:onProperty :isRWMSPart ],
        :AbstractEntity,
        :dul_Description,
        owl:Thing .

:GroundedSchema a owl:Class ;
    rdfs:label "GroundedSchema"^^xsd:string ;
    rdfs:subClassOf owl:Thing .

:GroundingCommitment a owl:Class ;
    rdfs:label "GroundingCommitment"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :collectedInto ;
            owl:someValuesFrom :GroundingRecord ],
        [ a owl:Restriction ;
            owl:hasValue true ;
            owl:onProperty :isRevisable ],
        [ a owl:Restriction ;
            owl:onProperty :constructedBy ;
            owl:someValuesFrom :TaskGrounding ],
        :AbstractEntity,
