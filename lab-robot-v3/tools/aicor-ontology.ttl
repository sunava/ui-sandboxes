:IntervalTemporalLogic a owl:Class ;
    rdfs:label "IntervalTemporalLogic"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :reifies ;
            owl:someValuesFrom :ReifiedTemporalEntity ],
        [ a owl:Restriction ;
            owl:onProperty :hasPredicate ;
            owl:someValuesFrom :TemporalPredicate ],
        [ a owl:Restriction ;
            owl:onProperty :reasonsOver ;
            owl:someValuesFrom :Chronicle ],
        :AbstractEntity,
        :dul_InformationObject,
        owl:Thing .

:KRRResource a owl:Class ;
    rdfs:label "KRRResource"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :makesConcrete ;
            owl:someValuesFrom :KRRHypothesis ],
        [ a owl:Restriction ;
            owl:hasValue "true, isInspectable value true"^^xsd:string ;
            owl:onProperty :isExplicit ],
        [ a owl:Restriction ;
            owl:onProperty :resourceFor ;
            owl:someValuesFrom :ManipulationExecutive ],
        [ a owl:Restriction ;
            owl:hasValue "true, isOperational value true"^^xsd:string ;
            owl:onProperty :isRevisable ],
        :AbstractEntity,
        :dul_Description,
        owl:Thing ;
    owl:disjointWith :BodyWorldSystem .

:KinematicRedundancy a owl:Class ;
    rdfs:label "KinematicRedundancy"^^xsd:string ;
    rdfs:subClassOf :dul_Quality,
        owl:Thing .

:KinematicSingularity a owl:Class ;
    rdfs:label "KinematicSingularity"^^xsd:string ;
    rdfs:subClassOf :dul_Quality,
        owl:Thing .

:MaintenanceGoal a owl:Class ;
    rdfs:label "MaintenanceGoal"^^xsd:string ;
    rdfs:subClassOf :Goal,
        owl:Thing .

:ManipulationProblem a owl:Class ;
    rdfs:label "ManipulationProblem"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :assignsClass ;
            owl:someValuesFrom :TaskRelativeClass ],
        [ a owl:Restriction ;
            owl:hasValue true ;
            owl:onProperty :isGrounded ],
        [ a owl:Restriction ;
            owl:onProperty :hasGoal ;
            owl:someValuesFrom :Goal ],
        [ a owl:Restriction ;
            owl:onClass :BodyWorldSystem ;
            owl:onProperty :relativeTo ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onProperty :classifies ;
            owl:someValuesFrom :BodyWorldTrajectory ],
        :dul_Description,
        owl:Thing ;
    owl:disjointWith :RobotWorldManipulationSystem .

:ManipulationTaskSpecification a owl:Class ;
    rdfs:label "ManipulationTaskSpecification"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :hasQualityFunctional ;
            owl:someValuesFrom :QualityFunctional ],
        [ a owl:Restriction ;
            owl:onProperty :hasGoal ;
            owl:someValuesFrom :Goal ],
        :dul_Description,
        owl:Thing .

:MasteryClaim a owl:Class ;
    rdfs:label "MasteryClaim"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :satisfies ;
