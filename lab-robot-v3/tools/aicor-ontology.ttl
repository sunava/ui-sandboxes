            owl:onProperty :hasFilmThickness ;
            owl:someValuesFrom :FilmThickness ],
        [ a owl:Restriction ;
            owl:onProperty :hasCoverageTarget ;
            owl:someValuesFrom :SpreadRadius ],
        [ a owl:Restriction ;
            owl:onProperty :onFlatObject ;
            owl:someValuesFrom :dul_PhysicalObject ],
        [ a owl:Restriction ;
            owl:onProperty :hasSpreadRadius ;
            owl:someValuesFrom :SpreadRadius ],
        :BodyWorldProcessMicrotheory,
        owl:Thing .

:OpenUpEvent a owl:Class ;
    rdfs:label "OpenUpEvent"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :initiatesStateType ;
            owl:someValuesFrom :OpenContainerState ],
        [ a owl:Restriction ;
            owl:onProperty :actsOnState ;
            owl:someValuesFrom :CrackedContainerState ],
        :EventType,
        owl:Thing .

:ParameterSample a owl:Class ;
    rdfs:label "ParameterSample"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
