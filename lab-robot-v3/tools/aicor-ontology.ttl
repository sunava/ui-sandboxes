        [ a owl:Restriction ;
            owl:onProperty :overProblemFamily ;
            owl:someValuesFrom :ManipulationProblemClass ],
        [ a owl:Restriction ;
            owl:onProperty :strengthens ;
            owl:someValuesFrom :CompetenceClaim ],
        :AbstractEntity,
        :dul_Description,
        owl:Thing .

:ModelPredictiveControl a owl:Class ;
    rdfs:label "ModelPredictiveControl"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :appliesFirstOf ;
            owl:someValuesFrom :ControlSequence ],
        [ a owl:Restriction ;
            owl:onProperty :optimizes ;
