:StructuredReactiveController a owl:Class ;
    rdfs:label "StructuredReactiveController"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :calls ;
            owl:someValuesFrom :ProcessModule ],
        [ a owl:Restriction ;
            owl:onProperty :mirrors ;
            owl:someValuesFrom :ForceDynamicSchema ],
        [ a owl:Restriction ;
            owl:hasValue true ;
            owl:onProperty :system2 ],
        [ a owl:Restriction ;
            owl:onProperty :hasPolicy ;
            owl:someValuesFrom :ConcurrentPolicy ],
        [ a owl:Restriction ;
            owl:onClass :PrimaryActivity ;
            owl:onProperty :hasPrimaryActivity ;
